import tkinter as tk
from tkinter import ttk, messagebox, simpledialog
from sqlalchemy import create_engine, Column, Integer, String, ForeignKey
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import sessionmaker, relationship
import webbrowser
import threading
import time
import requests
import uvicorn
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import re


Base = declarative_base()

class User(Base):
    __tablename__ = 'users'
    id = Column(Integer, primary_key=True)
    username = Column(String(50), unique=True, nullable=False)
    password = Column(String(100), nullable=False)
    videos = relationship("Video", back_populates="user")

class Video(Base):
    __tablename__ = 'videos'
    id = Column(Integer, primary_key=True)
    title = Column(String(200), nullable=False)
    url = Column(String(500))
    user_id = Column(Integer, ForeignKey('users.id'))
    user = relationship("User", back_populates="videos")

engine = create_engine('sqlite:///studyhub.db', echo=False)
Base.metadata.create_all(engine)
Session = sessionmaker(bind=engine)

# ====================== FASTAPI ======================
app = FastAPI(title="StudyHub API")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

class LoginData(BaseModel):
    username: str
    password: str

class VideoData(BaseModel):
    title: str
    url: str = None
    user_id: int

@app.post("/api/login")
def api_login(data: LoginData):
    session = Session()
    user = session.query(User).filter_by(username=data.username, password=data.password).first()
    session.close()
    if user:
        return {"success": True, "user_id": user.id, "username": user.username}
    return {"success": False, "message": "Invalid credentials"}, 401

@app.post("/api/register")
def api_register(data: LoginData):
    session = Session()
    if session.query(User).filter_by(username=data.username).first():
        session.close()
        return {"success": False, "message": "Username already taken"}, 400
    new_user = User(username=data.username, password=data.password)
    session.add(new_user)
    session.commit()
    session.close()
    return {"success": True, "message": "Account created successfully"}

@app.get("/api/videos/{user_id}")
def api_get_videos(user_id: int):
    session = Session()
    videos = session.query(Video).filter_by(user_id=user_id).all()
    session.close()
    return [{"id": v.id, "title": v.title, "url": v.url} for v in videos]

@app.post("/api/videos")
def api_add_video(data: VideoData):
    session = Session()
    video = Video(title=data.title, url=data.url, user_id=data.user_id)
    session.add(video)
    session.commit()
    session.close()
    return {"success": True, "message": "Video added"}

def run_fastapi():
    uvicorn.run(app, host="127.0.0.1", port=5000, log_level="warning")

# ====================== GUI APP ======================
class StudyingApp:
    def __init__(self, root):
        self.root = root
        self.root.title("StudyHub - Learning Platform")
        self.root.geometry("960x740")
        self.current_user = None
        self.current_user_id = None
        self.API_URL = "http://127.0.0.1:5000/api"

        threading.Thread(target=run_fastapi, daemon=True).start()
        time.sleep(2)

        self.show_start_menu()

    def clear_window(self):
        for widget in self.root.winfo_children():
            widget.destroy()

    # ==================== START MENU ====================
    def show_start_menu(self):
        self.clear_window()
        frame = ttk.Frame(self.root, padding=50)
        frame.pack(expand=True, fill="both")

        ttk.Label(frame, text="📚 StudyHub", font=("Helvetica", 42, "bold")).pack(pady=30)
        ttk.Label(frame, text="Your Personal Study Companion", font=("Arial", 16)).pack(pady=8)

        ttk.Separator(frame).pack(fill="x", pady=25)

        btn_frame = ttk.Frame(frame)
        btn_frame.pack(pady=30)

        style = ttk.Style()
        style.configure("Big.TButton", font=("Arial", 14), padding=15)

        ttk.Button(btn_frame, text="🚀 Start Application",
                  command=self.ask_to_start, style="Big.TButton").pack(pady=12, ipadx=40)

        ttk.Button(btn_frame, text="ℹ️ About", command=self.show_about).pack(pady=5)
        ttk.Button(btn_frame, text="❌ Exit", command=self.root.quit).pack(pady=5)

    def ask_to_start(self):
        if messagebox.askyesno("Start StudyHub?", "Do you want to start the application now?"):
            self.show_trial_screen()
        else:
            messagebox.showinfo("Okay", "You can start anytime.")

    def show_trial_screen(self):
        self.clear_window()
        frame = ttk.Frame(self.root, padding=40)
        frame.pack(expand=True, fill="both")

        ttk.Label(frame, text="🎉 Welcome to StudyHub!", font=("Helvetica", 28, "bold")).pack(pady=20)
        ttk.Label(frame, text="7-Day Free Trial Activated", font=("Arial", 18, "bold"), foreground="green").pack(pady=10)
        ttk.Label(frame, text="After trial: $4.99 / month", font=("Arial", 14)).pack()

        price = ttk.LabelFrame(frame, text=" What You Get ", padding=20)
        price.pack(pady=30, fill="x", padx=50)
        ttk.Label(price, text="✅ Unlimited Video Library\n✅ Progress Tracking\n✅ Personal Dashboard",
                 font=("Arial", 12)).pack(anchor="w", pady=10)

        ttk.Button(frame, text="✅ Continue with Free Trial",
                  command=self.start_trial, style="Big.TButton").pack(pady=25, ipadx=30, ipady=10)

        ttk.Button(frame, text="← Back", command=self.show_start_menu).pack()

    def start_trial(self):
        messagebox.showinfo("Trial Started", "Your 7-day free trial has been activated!\nFull access granted.")
        self.show_login_screen()

    # ==================== LOGIN ====================
    def show_login_screen(self):
        self.clear_window()
        frame = ttk.Frame(self.root, padding=40)
        frame.pack(expand=True)

        ttk.Label(frame, text="Login", font=("Helvetica", 26, "bold")).pack(pady=20)

        ttk.Label(frame, text="Username:").pack(anchor="w")
        self.username_var = tk.StringVar()
        ttk.Entry(frame, textvariable=self.username_var, width=45).pack(pady=8)

        ttk.Label(frame, text="Password:").pack(anchor="w")
        self.password_var = tk.StringVar()
        ttk.Entry(frame, textvariable=self.password_var, show="*", width=45).pack(pady=8)

        btn_frame = ttk.Frame(frame)
        btn_frame.pack(pady=25)
        ttk.Button(btn_frame, text="Login", command=self.attempt_login).pack(side="left", padx=10)
        ttk.Button(btn_frame, text="Create Account", command=self.show_register).pack(side="left", padx=10)
        ttk.Button(btn_frame, text="← Back", command=self.show_start_menu).pack(side="left", padx=10)

    def attempt_login(self):
        username = self.username_var.get().strip()
        password = self.password_var.get().strip()
        try:
            resp = requests.post(f"{self.API_URL}/login", json={"username": username, "password": password})
            data = resp.json()
            if data.get("success"):
                self.current_user = data["username"]
                self.current_user_id = data["user_id"]
                messagebox.showinfo("Success", f"Welcome, {self.current_user}!")
                self.show_main_dashboard()
            else:
                messagebox.showerror("Error", data.get("message"))
        except:
            messagebox.showerror("Connection Error", "FastAPI server not responding.")

    # ==================== REGISTER with Password Strength ====================
    def show_register(self):
        self.clear_window()
        frame = ttk.Frame(self.root, padding=40)
        frame.pack(expand=True)

        ttk.Label(frame, text="Create New Account", font=("Helvetica", 26, "bold")).pack(pady=20)

        ttk.Label(frame, text="Username:").pack(anchor="w")
        self.reg_username_var = tk.StringVar()
        ttk.Entry(frame, textvariable=self.reg_username_var, width=45).pack(pady=8)

        ttk.Label(frame, text="Password:").pack(anchor="w")
        self.reg_password_var = tk.StringVar()
        self.password_entry = ttk.Entry(frame, textvariable=self.reg_password_var, show="*", width=45)
        self.password_entry.pack(pady=8)
        self.password_entry.bind("<KeyRelease>", self.check_password_strength)

        # Strength Indicator
        self.strength_label = ttk.Label(frame, text="Password Strength: ", font=("Arial", 11))
        self.strength_label.pack(anchor="w", pady=(10, 0))

        self.strength_bar = ttk.Progressbar(frame, length=300, mode='determinate')
        self.strength_bar.pack(anchor="w", pady=5)

        self.strength_text = ttk.Label(frame, text="", font=("Arial", 10, "bold"))
        self.strength_text.pack(anchor="w")

        ttk.Button(frame, text="Register", command=self.register_user).pack(pady=25)
        ttk.Button(frame, text="← Back to Login", command=self.show_login_screen).pack()

    def check_password_strength(self, event=None):
        password = self.reg_password_var.get()
        score = 0
        feedback = ""

        if len(password) >= 8:
            score += 1
        if re.search(r"[A-Z]", password):
            score += 1
        if re.search(r"[a-z]", password):
            score += 1
        if re.search(r"[0-9]", password):
            score += 1
        if re.search(r"[@$!%*?&]", password):
            score += 1

        # Animate strength
        if score <= 2:
            color = "red"
            text = "Weak"
            value = 33
            feedback = "Tip: Use uppercase, numbers & symbols"
        elif score <= 4:
            color = "orange"
            text = "Medium"
            value = 66
            feedback = "Good! Add more variety"
        else:
            color = "green"
            text = "Strong"
            value = 100
            feedback = "Excellent password!"

        self.strength_bar['value'] = value
        self.strength_text.config(text=text, foreground=color)
        self.strength_label.config(text=f"Password Strength: {feedback}")

    def register_user(self):
        username = self.reg_username_var.get().strip()
        password = self.reg_password_var.get().strip()

        if len(password) < 6:
            messagebox.showerror("Weak Password", "Password must be at least 6 characters.")
            return

        try:
            resp = requests.post(f"{self.API_URL}/register", json={"username": username, "password": password})
            data = resp.json()
            if data.get("success"):
                messagebox.showinfo("Success", "Account created successfully! Please login.")
                self.show_login_screen()
            else:
                messagebox.showerror("Error", data.get("message"))
        except:
            messagebox.showerror("Error", "Cannot connect to server.")

    # ==================== MAIN DASHBOARD ====================
    def show_main_dashboard(self):
        self.clear_window()
        top = ttk.Frame(self.root)
        top.pack(fill="x", padx=15, pady=8)
        ttk.Label(top, text=f"👋 Welcome, {self.current_user}", font=("Arial", 16, "bold")).pack(side="left")
        ttk.Button(top, text="Logout", command=self.show_start_menu).pack(side="right")

        notebook = ttk.Notebook(self.root)
        notebook.pack(expand=True, fill="both", padx=10, pady=10)

        videos_tab = ttk.Frame(notebook)
        notebook.add(videos_tab, text="📹 My Videos")

        self.video_listbox = tk.Listbox(videos_tab, font=("Arial", 11), height=22)
        self.video_listbox.pack(expand=True, fill="both", padx=10, pady=10)

        btn_frame = ttk.Frame(videos_tab)
        btn_frame.pack(pady=8)
        ttk.Button(btn_frame, text="➕ Add Video", command=self.add_new_video).pack(side="left", padx=5)
        ttk.Button(btn_frame, text="▶ Play", command=self.play_selected_video).pack(side="left", padx=5)
        ttk.Button(btn_frame, text="🗑 Delete", command=self.delete_video).pack(side="left", padx=5)

        self.load_videos()

        notebook.add(ttk.Frame(notebook), text="📚 Courses")
        notebook.add(ttk.Frame(notebook), text="📊 Progress")

    def load_videos(self):
        try:
            resp = requests.get(f"{self.API_URL}/videos/{self.current_user_id}")
            videos = resp.json()
            self.video_listbox.delete(0, tk.END)
            for v in videos:
                self.video_listbox.insert(tk.END, f"• {v['title']}  [{v.get('url') or 'No link'}]")
        except:
            pass

    def add_new_video(self):
        title = simpledialog.askstring("Add Video", "Video Title:")
        if not title: return
        url = simpledialog.askstring("URL", "Video URL:", initialvalue="https://")
        try:
            requests.post(f"{self.API_URL}/videos", json={"title": title, "url": url, "user_id": self.current_user_id})
            self.load_videos()
            messagebox.showinfo("Success", "Video added!")
        except:
            messagebox.showerror("Error", "Failed to add video")

    def play_selected_video(self):
        sel = self.video_listbox.curselection()
        if not sel:
            messagebox.showwarning("Select", "Please select a video first.")
            return
        webbrowser.open("https://youtube.com")

    def delete_video(self):
        messagebox.showinfo("Coming Soon", "Delete feature coming soon.")

    def show_about(self):
        messagebox.showinfo("About", "StudyHub v1.4\nFastAPI + Tkinter + Password Strength Animation")

if __name__ == "__main__":
    root = tk.Tk()
    style = ttk.Style()
    style.configure("Big.TButton", font=("Arial", 14), padding=12)
    StudyingApp(root)
    root.mainloop()
